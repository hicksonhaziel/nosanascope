# Core runtime
ELIZAOS_API_KEY=eliza_your_api_key_here
PGLITE_DATA_DIR=.eliza/.elizadb
LOG_LEVEL=info

# Nosana API
NOSANA_API_KEY=nos_your_api_key_here

# Required for spawn/restart workflows (must be valid JSON)
NOSANA_JOB_TEMPLATE={"name":"my-deployment","market":"<market-address>","strategy":"random","replicas":1,"timeout":60,"job_definition":{"ops":[]}}

# Metrics database (optional override)
POSTGRES_URL=
NOSANA_METRICS_POSTGRES_URL=postgresql://agent:agent_password@127.0.0.1:5432/nosanascope

# Telegram alerts (optional, but set both to enable alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Evaluator debug logging
NOSANA_DEBUG_EVALUATORS=false
